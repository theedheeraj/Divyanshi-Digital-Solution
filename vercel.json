{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    { "src": "^/api/(.*)", "dest": "/server/index.js" },
    { "src": "^/admin/(.*)", "dest": "/client/index.html" },
    { "src": "^/((?!api/).*)$", "dest": "/client/index.html" }
  ]
}
